{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build --force",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "test": "vitest run --exclude 'tests/e2e/**' --exclude 'tests/smoke/**'",
    "test:unit": "vitest run tests/unit",
    "test:api": "vitest run tests/api",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage --exclude 'tests/e2e/**' --exclude 'tests/smoke/**'",
    "test:smoke:xrpl": "node tests/smoke/xrpl-smoke.mjs",
    "test:ci": "pnpm run typecheck && pnpm run build && pnpm run test && pnpm run test:e2e"
  },
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "node-mocks-http": "^1.17.2",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.9"
  }
}
